DATABASE_URL=postgresql+asyncpg://futureapp:replace-this@db:5432/futureapp
SECRET_KEY=replace-with-strong-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
SQL_ECHO=false
CORS_ORIGINS=https://patient.example.com,https://admin.example.com
OLLAMA_BASE_URL=http://ollama:11434
EMBEDDING_MODEL=nomic-embed-text
SIMILARITY_THRESHOLD_DIRECT=0.85
SIMILARITY_THRESHOLD_RELEVANT=0.30
CLIENT_ERROR_DEDUPE_WINDOW_SECONDS=60
CLIENT_ERROR_DEDUPE_CACHE_SIZE=2000
MAX_UPLOAD_SIZE_MB=20
RESPONSE_CACHE_SIZE=500
RESPONSE_CACHE_TTL=3600
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=replace-with-strong-admin-password
BOOTSTRAP_BOT_PASSWORD=replace-with-strong-bot-password